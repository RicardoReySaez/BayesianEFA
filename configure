#! /bin/sh

# Generated by rstantools.  Do not edit by hand.

"${R_HOME}/bin/Rscript" -e "rstantools::rstan_config()"

# 2. Patch src/Makevars to add Armadillo linker flags
"${R_HOME}/bin/Rscript" -e "
  f <- 'src/Makevars'
  if(file.exists(f)) {
    lines <- readLines(f)

    # --- Add Armadillo (LAPACK/BLAS) if missing ---
    idx_libs <- grep('^PKG_LIBS', lines)
    if(length(idx_libs) > 0 && !grepl('LAPACK_LIBS', lines[idx_libs])) {
      libs <- paste0('$', '(LAPACK_LIBS) $', '(BLAS_LIBS) $', '(FLIBS)')
      lines[idx_libs] <- paste(lines[idx_libs], libs)
      cat(' -> [configure] Armadillo flags added.\\n')
    }

    writeLines(lines, f)
  }
"
